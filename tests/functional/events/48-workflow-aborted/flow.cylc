[scheduler]
    allow implicit tasks = True
    [[main loop]]
        [[[health check]]]
            interval = PT1S
    [[events]]
        abort handlers = echo %(event)s "%(message)s" >"${CYLC_WORKFLOW_RUN_DIR}/handler.out"
        # These settings make the test avoid hanging if something goes wrong (nothing to do with the actual abort test):
        abort on inactivity timeout = true
        inactivity timeout = PT30S
        abort on stall timeout = true
        stall timeout = PT0S
[scheduling]
    [[graph]]
        R1 = modify => t2

[runtime]
    [[modify]]
        script = """
            # Pause the workflow, so it does not shutdown
            cylc pause "${CYLC_WORKFLOW_ID}"
            # Cause abort by making health check fail (contact file modified)
            echo 'TIME=MONEY' >>"${CYLC_WORKFLOW_RUN_DIR}/.service/contact"
        """
