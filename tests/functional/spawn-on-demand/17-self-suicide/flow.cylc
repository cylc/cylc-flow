# https://github.com/cylc/cylc-flow/issues/4968: self-induced suicide should
# not retrigger foo below.

[scheduler]
    [[events]]
        stall timeout = PT0S
        abort on stall timeout = True
        expected task failures = 1/foo

[scheduling]
    [[dependencies]]
        graph = """
            foo? => bar
            foo:fail? => !foo & !bar
            foo:fail? | bar => baz
        """

[runtime]
    [[foo]]
        script = false
    [[bar, baz]]
